generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(cuid())
  name             String
  last_name        String
  email            String        @unique
  password         String
  role             String        @default("supervisor")
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime?     @updatedAt @map("updated_at")
  
  devices          Device[]
  schedules ScheduleSet[]
  rules     Rule[]
  
  createdEmployees Employee[] @relation("CreatedEmployees")
  updatedEmployees Employee[] @relation("UpdatedEmployees")
  createdAbsences  Absence[]     @relation("AbsenceCreator")
  updatedAbsences  Absence[]     @relation("AbsenceUpdater")

}

model ScheduleSet {
  id          String           @id @default(cuid())
  name        String
  description String?
  is_active   Boolean          @default(true)
  created_by  String
  created_at  DateTime         @default(now()) @map("created_at")
  updated_at  DateTime?        @updatedAt @map("updated_at")
  updated_by  String?
  employees   Employee[]
  details     ScheduleDetail[]
  creator     User             @relation(fields: [created_by], references: [id])

  @@index([created_by], map: "ScheduleSet_created_by_fkey")
}

model ScheduleDetail {
  id               String       @id @default(cuid())
  week_day         Int
  check_in         DateTime
  check_out        DateTime
  lunch_start      DateTime?
  lunch_end        DateTime?
  created_at       DateTime     @default(now()) @map("created_at")
  updated_at       DateTime?    @updatedAt @map("updated_at")
  created_by       String
  updated_by       String?
  schedules_set_id String
  attendances      Attendance[]
  absences         Absence[]
  schedule_set     ScheduleSet  @relation(fields: [schedules_set_id], references: [id])
  @@index([schedules_set_id], map: "ScheduleDetail_schedules_set_id_fkey")
}

model Employee {
  id              String       @id @default(cuid())
  name            String
  last_name       String
  matricula       String       @unique
  phone           String       @unique
  facial_vector   Json?
  URL_photo       String?
  active          Boolean      @default(true)
  created_by_id   String
  updated_by_id   String?
  schedule_set_id String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime?    @updatedAt @map("updated_at")
  attendances     Attendance[]
  created_by      User         @relation("CreatedEmployees", fields: [created_by_id], references: [id])
  schedule_set    ScheduleSet? @relation(fields: [schedule_set_id], references: [id])
  updated_by      User?        @relation("UpdatedEmployees", fields: [updated_by_id], references: [id])
  rules           Rule[]
  absences     Absence[]

  @@index([created_by_id], map: "Employee_created_by_id_fkey")
  @@index([schedule_set_id], map: "Employee_schedule_set_id_fkey")
  @@index([updated_by_id], map: "Employee_updated_by_id_fkey")


}

model Rule {
  id            String    @id @default(cuid())
  name          String
  type          String
  description   String?
  valid         Boolean   @default(true)
  is_global     Boolean   @default(false) @map("is_global")
  employee_id   String?
  created_by_id String
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  created_by    User      @relation(fields: [created_by_id], references: [id])
  employee      Employee? @relation(fields: [employee_id], references: [id])

  @@index([created_by_id], map: "rules_created_by_id_fkey")
  @@index([employee_id], map: "rules_employee_id_fkey")
  @@map("rules")
}

model Attendance {
  id                 String         @id @default(cuid())
  employee_id        String
  schedule_detail_id String
  date               DateTime
  week_day           Int
  check_in           DateTime?
  check_out          DateTime?
  lunch_start        DateTime?
  lunch_end          DateTime?
  employee           Employee       @relation(fields: [employee_id], references: [id])
  schedule_detail    ScheduleDetail @relation(fields: [schedule_detail_id], references: [id])

  @@index([employee_id], map: "Attendance_employee_id_fkey")
  @@index([schedule_detail_id], map: "Attendance_schedule_detail_id_fkey")
}

model Device {
  id            String   @id @default(cuid())
  name          String?
  token         String   @unique
  device_id     String?
  is_active     Boolean  @default(true)
  last_seen_at  DateTime @default(now())
  created_at    DateTime @default(now())
  created_by_id String
  created_by    User     @relation(fields: [created_by_id], references: [id])

  @@index([created_by_id], map: "Device_created_by_id_fkey")
  }
  
model Absence {
  id                String       @id @default(cuid())
  employee_id       String
  schedule_detail_id String?
  type              String
  start_date        DateTime
  end_date          DateTime
  reason            String?
  status            String       @default("pending")
  created_by        String
  created_at        DateTime     @default(now()) @map("created_at")
  updated_by        String?
  updated_at        DateTime?    @updatedAt @map("updated_at")

  employee        Employee       @relation(fields: [employee_id], references: [id])
  schedule_detail ScheduleDetail? @relation(fields: [schedule_detail_id], references: [id])
  creator         User           @relation("AbsenceCreator", fields: [created_by], references: [id])
  updater         User?          @relation("AbsenceUpdater", fields: [updated_by], references: [id])

  @@map("absences")
}
